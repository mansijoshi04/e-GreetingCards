# ============================================================
# GifLove — Environment Variable Reference
# ============================================================
# Copy this file to the appropriate env file and fill in values:
#   Local dev → .env.local
#   Staging   → .env.staging  (on VPS only, never committed)
#   Production → .env.prod    (on VPS only, never committed)
#
# NEVER commit .env.local, .env.staging, or .env.prod to git.
# Update THIS file whenever a new variable is added.
# ============================================================

# ---------------------------------------------------------------------------
# Django
# ---------------------------------------------------------------------------
DJANGO_SECRET_KEY=change-me-generate-with-python-c-import-secrets-print-secrets.token_hex-50
DJANGO_SETTINGS_MODULE=giflove.settings.production   # development for local

ALLOWED_HOSTS=giflove.ca,staging.giflove.ca          # comma-separated
CORS_ALLOWED_ORIGINS=https://giflove.ca,https://staging.giflove.ca

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
POSTGRES_DB=giflove
POSTGRES_USER=giflove_user
POSTGRES_PASSWORD=change-me-strong-password
POSTGRES_HOST=db          # 'db' inside Docker; 'localhost' outside
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0   # 'redis' = Docker service name

# ---------------------------------------------------------------------------
# MinIO — self-hosted S3-compatible object storage
#
# MINIO_ROOT_USER / MINIO_ROOT_PASSWORD
#   → Credentials for the MinIO server itself (used by the minio-init container)
#
# MINIO_ACCESS_KEY / MINIO_SECRET_KEY
#   → Credentials Django uses to connect to MinIO via boto3
#     (can be the same as root in dev; use a dedicated service account in prod)
#
# MINIO_ENDPOINT_URL
#   → Internal URL Django/boto3 uses to call MinIO API
#     Inside Docker: http://minio:9000
#
# MINIO_PUBLIC_URL
#   → External URL embedded in Card.media_url so browsers can load files
#     Dev:     http://localhost:9000
#     Staging: https://staging.giflove.ca/media
#     Prod:    https://giflove.ca/media
# ---------------------------------------------------------------------------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me-strong-password
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=change-me-strong-password
MINIO_BUCKET_NAME=giflove-prod          # giflove-dev / giflove-staging / giflove-prod
MINIO_ENDPOINT_URL=http://minio:9000    # internal Docker URL
MINIO_PUBLIC_URL=https://giflove.ca/media  # browser-accessible URL
MINIO_USE_SSL=False                     # True only if MinIO itself terminates SSL

# ---------------------------------------------------------------------------
# Paddle (payments)
# ---------------------------------------------------------------------------
PADDLE_API_KEY=pdl_live_apikey_...
PADDLE_WEBHOOK_SECRET=ntf_...
PADDLE_ENVIRONMENT=production           # 'sandbox' for staging/dev
PADDLE_ESSENTIAL_PRICE_ID=pri_...
PADDLE_PREMIUM_PRICE_ID=pri_...
PADDLE_BULK_PRICE_ID=pri_...

# ---------------------------------------------------------------------------
# Resend (transactional email)
# ---------------------------------------------------------------------------
RESEND_API_KEY=re_...
EMAIL_FROM=cards@giflove.ca
EMAIL_PROVIDER=resend                   # 'console' prints to stdout (no real emails)

# ---------------------------------------------------------------------------
# App
# ---------------------------------------------------------------------------
BASE_URL=https://giflove.ca             # staging: https://staging.giflove.ca

# ---------------------------------------------------------------------------
# Frontend (Vite) — VITE_ prefix required; exposed to browser bundle
# ---------------------------------------------------------------------------
VITE_API_BASE_URL=/api                                  # proxied by Vite dev server / nginx in prod
VITE_PADDLE_ENVIRONMENT=sandbox                         # 'production' in prod
VITE_PADDLE_CLIENT_TOKEN=live_placeholder_replace_me    # Paddle client-side token
VITE_PADDLE_PRICE_ESSENTIAL=pri_...                     # Paddle price ID for Essential tier
VITE_PADDLE_PRICE_PREMIUM=pri_...                       # Paddle price ID for Premium tier
VITE_PADDLE_PRICE_BULK=pri_...                          # Paddle price ID for Bulk tier
