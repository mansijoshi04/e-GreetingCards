// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User-Created Cards
model Card {
  id               String    @id @default(uuid())
  templateId       String    @map("template_id") // slug matching registry id e.g. 'balloon-party'

  // Sender Information
  senderEmail      String?   @map("sender_email")
  senderName       String    @map("sender_name")

  // Card Content
  customText       String    @map("custom_text") // {headline, body, signature} - JSON string
  customStyling    String?   @map("custom_styling") // {colors, fonts} overrides - JSON string

  // Link Management
  linkToken        String    @unique @map("link_token")
  expiresAt        DateTime  @map("expires_at")

  // Payment
  stripePaymentId  String?   @map("stripe_payment_id")
  amountPaidCents  Int       @map("amount_paid_cents")
  isPaid           Boolean   @default(false) @map("is_paid")

  // Metadata
  createdAt        DateTime  @default(now()) @map("created_at")
  lastAccessedAt   DateTime? @map("last_accessed_at")

  recipients       Recipient[]
  opens            CardOpen[]

  @@index([linkToken])
  @@index([expiresAt])
  @@map("cards")
}

// Recipients (many-to-one with cards)
model Recipient {
  id              String    @id @default(uuid())
  cardId          String    @map("card_id")
  recipientEmail  String    @map("recipient_email")

  // Tracking
  emailSentAt     DateTime? @map("email_sent_at")
  firstOpenedAt   DateTime? @map("first_opened_at") // NULL until opened
  openCount       Int       @default(0) @map("open_count")
  lastOpenedAt    DateTime? @map("last_opened_at")

  createdAt       DateTime  @default(now()) @map("created_at")

  card            Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  opens           CardOpen[]

  @@index([cardId])
  @@map("recipients")
}

// Analytics (detailed tracking)
model CardOpen {
  id            String    @id @default(uuid())
  cardId        String    @map("card_id")
  recipientId   String?   @map("recipient_id")

  // Context
  openedAt      DateTime  @default(now()) @map("opened_at")
  userAgent     String?
  ipAddress     String?
  referrer      String?
  deviceType    String?   @map("device_type") // mobile, desktop, tablet

  card          Card      @relation(fields: [cardId], references: [id], onDelete: Cascade)
  recipient     Recipient? @relation(fields: [recipientId], references: [id])

  @@index([cardId])
  @@map("card_opens")
}
