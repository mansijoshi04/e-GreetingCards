# Database
POSTGRES_USER=greeting_user
POSTGRES_PASSWORD=greeting_password
POSTGRES_DB=greeting_cards
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# App
APP_PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# Paddle (get from https://sandbox-vendors.paddle.com)
PADDLE_API_KEY=YOUR_SANDBOX_API_KEY_HERE
PADDLE_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE
PADDLE_ENVIRONMENT=sandbox
PADDLE_BASIC_PRICE_ID=pri_YOUR_BASIC_PRICE_ID
PADDLE_PREMIUM_PRICE_ID=pri_YOUR_PREMIUM_PRICE_ID

# SendGrid (get from https://sendgrid.com/account)
SENDGRID_API_KEY=SG.YOUR_API_KEY_HERE
SENDGRID_FROM_EMAIL=cards@yourdomain.com
