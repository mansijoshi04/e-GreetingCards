# Database
POSTGRES_USER=greeting_user
POSTGRES_PASSWORD=greeting_password
POSTGRES_DB=greeting_cards
POSTGRES_PORT=5432

# Redis
REDIS_PORT=6379

# App
APP_PORT=3000
BASE_URL=http://localhost:3000
NODE_ENV=development

# Paddle (get from sandbox-vendors.paddle.com for sandbox, vendors.paddle.com for production)
PADDLE_API_KEY=YOUR_SANDBOX_API_KEY_HERE
PADDLE_WEBHOOK_SECRET=YOUR_WEBHOOK_SECRET_HERE
PADDLE_ENVIRONMENT=sandbox
PADDLE_BASIC_PRICE_ID=pri_YOUR_BASIC_PRICE_ID
PADDLE_PREMIUM_PRICE_ID=pri_YOUR_PREMIUM_PRICE_ID
NEXT_PUBLIC_PADDLE_CLIENT_TOKEN=YOUR_CLIENT_TOKEN_HERE

# Email — provider is controlled by EMAIL_PROVIDER
# "console" → logs to stdout (local dev default)
# "resend"  → sends via Resend API (production)
EMAIL_PROVIDER=console
EMAIL_FROM=cards@giflove.ca

# Resend (get from resend.com — free up to 3k emails/month)
# Only needed when EMAIL_PROVIDER=resend
RESEND_API_KEY=re_YOUR_API_KEY_HERE
